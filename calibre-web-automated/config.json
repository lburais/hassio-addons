{
    "apparmor": true,
    "arch": [
      "aarch64",
      "amd64"
    ],
    "boot": "auto",
    "description": "Calibre-Web Automated ebook library manager",
    "environment": {
      "TZ": "Europe/Paris",
      "PUID": "501",
      "PGID": "20",
      "CONFIG_PATH": "/addon-config",
      "INGEST_PATH": "/share/Ra/Médias/Import",
      "LIBRARY_PATH": "/share/Ra/Médias/Livres",
      "NETWORK_SHARE_MODE": 0,
      "TRUSTED_PROXY_COUNT": 1,
      "DISABLE_LIBRARY_AUTOMOUNT": 0
    },
    "host_network": false,
    "homeassistant_api": true,
    "init": false,
    "map": [
      {
        "type": "addon_config",
        "read_only": false,
        "path": "/addon-config"
      },
      {
        "type": "share",
        "read_only": false,
        "path": "/share"
      },
      {
        "type": "media",
        "read_only": false,
        "path": "/media"
      }
    ], 
    "name": "Calibre-Web Automated",
    "options": {
      "TZ": "Europe/Paris",
      "PUID": 501,
      "PGID": 20,
      "CONFIG_PATH": "/addon-config",
      "INGEST_PATH": "/share/Ra/Médias/Import",
      "LIBRARY_PATH": "/share/Ra/Médias/Livres",
      "NETWORK_SHARE_MODE": false,
      "TRUSTED_PROXY_COUNT": 1,
      "DISABLE_LIBRARY_AUTOMOUNT": false
    },
    "panel_icon": "mdi:bookshelf",
    "ports": {
      "8083/tcp": 8083
    },
    "ports_description": {
      "8083/tcp": "Web interface"
    },
    "schema": {
      "TZ": "str?",
      "PUID": "int?",
      "PGID": "int?",
      "CONFIG_PATH": "str?",
      "INGEST_PATH": "str?",
      "LIBRARY_PATH": "str?",
      "NETWORK_SHARE_MODE": "bool",
      "TRUSTED_PROXY_COUNT": "int(1,10)?",
      "DISABLE_LIBRARY_AUTOMOUNT": "bool"
    },
    "slug": "calibre-web-automated",
    "stage": "experimental",
    "startup": "application",
    "url": "https://github.com/lburais/hassio-addons/tree/master/calibre-web-automated",
    "version": "1.0.2",
    "watchdog": "tcp://[HOST]:[PORT:8083]",
    "webui": "http://[HOST]:[PORT:8083]"
  }