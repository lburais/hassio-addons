{
    "apparmor": true,
    "arch": [
      "aarch64",
      "amd64"
    ],
    "boot": "auto",
    "description": "Calibre-Web Automated ebook library manager",
    "environment": {
      "TZ": "Europe/Paris",
      "PUID": "501",
      "PGID": "20",
      "CONFIG_PATH": "/share/docker/calibre-web-automated",
      "INGEST_PATH": "/share/médias/Import",
      "LIBRARY_PATH": "/share/médias/Livres",
      "NETWORK_SHARE_MODE": "0",
      "TRUSTED_PROXY_COUNT": "1",
      "DISABLE_LIBRARY_AUTOMOUNT": "0"
    },
    "host_network": false,
    "homeassistant_api": true,
    "init": false,
    "map": [
      {
        "type": "addon_config",
        "read_only": false,
        "path": "/share/docker/calibre-web-automated"
      },
      {
        "type": "share",
        "read_only": false,
        "path": "/share"
      },
      {
        "type": "media",
        "read_only": false,
        "path": "/share/médias"
      }
    ], 
    "name": "Calibre-Web Automated",
    "panel_icon": "mdi:bookshelf",
    "ports": {
      "8083/tcp": 8083
    },
    "ports_description": {
      "8083/tcp": "Web interface"
    },
    "slug": "calibre-web-automated",
    "stage": "experimental",
    "startup": "application",
    "url": "https://github.com/lburais/hassio-addons/tree/master/calibre-web-automated",
    "version": "1.0.2",
    "watchdog": "tcp://[HOST]:[PORT:8083]",
    "webui": "http://[HOST]:[PORT:8083]"
  }