{
  "apparmor": true,
  "arch": [
    "aarch64",
    "amd64"
  ],
  "boot": "auto",
  "description": "Calibre-Web Automated ebook library manager",
  "host_network": false,
  "init": false,
  "map": [
    "share:rw",
    "config:rw"
  ], 
  "name": "Calibre-Web Automated",
  "panel_icon": "mdi:bookshelf",
  "options": {
    "puid": 501,
    "pgid": 20,
    "tz": "Europe/Paris",
    "config": "/share/Docker/calibre-web-automated",
    "ingest": "/share/Medias/Import",
    "library": "/share/Medias/Livres",
    "network_share_mode": false
  },
  "ports": {
    "8083/tcp": 8083
  },
  "ports_description": {
    "8083/tcp": "Web interface"
  },
  "schema": {
    "puid": "int",
    "pgid": "int",
    "tz": "str",
    "config": "str",
    "ingest": "str",
    "library": "str",
    "network_share_mode": "bool"
  },
  "slug": "calibre-web-automated",
  "stage": "experimental",
  "startup": "application",
  "url": "https://github.com/lburais/hassio-addons/tree/master/calibre-web-automated",
  "version": "1.1.0",
  "watchdog": "tcp://[HOST]:[PORT:8083]",
  "webui": "http://[HOST]:[PORT:8083]"
}
