{
    "apparmor": true,
    "arch": [
      "aarch64",
      "amd64",
      "armv7"
    ],
    "boot": "auto",
    "description": "Portainer CE for Docker environment visibility from Home Assistant",
    "docker_api": true,
    "host_network": false,
    "init": false,
    "name": "Portainer",
    "panel_icon": "mdi:docker",
    "ports": {
      "8000/tcp": 8000,
      "9443/tcp": 9443
    },
    "ports_description": {
      "8000/tcp": "Edge agent tunnel",
      "9443/tcp": "HTTPS web interface"
    },
    "schema": false,
    "slug": "portainer",
    "stage": "experimental",
    "startup": "application",
    "url": "https://github.com/lburais/hassio-addons/tree/master/portainer",
    "version": "1.0.0",
    "watchdog": "tcp://[HOST]:[PORT:9443]",
    "webui": "https://[HOST]:[PORT:9443]"
  }